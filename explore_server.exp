#!/usr/bin/expect -f
set timeout 30
spawn ssh -i ssh_key.pem -o StrictHostKeyChecking=no root@updates.wegov.nyc "echo '---FILES---'; ls -la /var/www /opt; echo '---DOCKER---'; docker ps; echo '---PM2---'; pm2 list; echo '---NGINX---'; cat /etc/nginx/sites-enabled/default"
expect {
    "Enter passphrase*" {
        send "Sq;LfI)?~5O?\r"
        exp_continue
    }
    eof
}
